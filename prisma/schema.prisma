// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model ContactSubmission {
  id           String   @id @default(uuid())
  fullName     String
  organization String?
  title        String?
  phone        String
  email        String
  subject      String
  message      String
  createdAt    DateTime @default(now())
}

model QuoteRequest {
  id              String   @id @default(uuid())
  organization    String
  contactPerson   String
  title           String?
  phone           String
  email           String
  categories      String   // stored as JSON string or comma separated
  itemDescription String
  deliveryLocation String
  requiredByDate  DateTime?
  budgetRange     String?
  message         String?
  createdAt       DateTime @default(now())
}
